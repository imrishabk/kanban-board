generator client {
  provider = "prisma-client"
  output   = "../../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Boards {
  id        String    @id @default(cuid())
  title     String
  owner     Users?    @relation(fields: [ownerId], references: [id])
  ownerId   String?   @default("SERVER")
  group     Groups?   @relation(fields: [groupId], references: [id])
  groupId   String?   @default("SERVER")
  columns   Columns[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("boards")
}

model Columns {
  id        String   @id @default(cuid())
  title     String
  tasks     Tasks[]
  boards    Boards   @relation(fields: [boardId], references: [id])
  boardId   String   @map("board_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("columns")
}

model Tasks {
  id          String   @id @default(cuid())
  name        String
  description String?
  columns     Columns  @relation(fields: [columnId], references: [id])
  columnId    String   @map("column_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("tasks")
}

model Users {
  id          String     @id @default(cuid())
  username    String     @unique
  email       String     @unique
  password    String
  displayName String     @map("display_name")
  groups      Groups[]
  sessions    Sessions[]
  tokens      Tokens[]
  boards      Boards[]
  isActive    Boolean    @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("users")
}

model Groups {
  id        String   @id @default(cuid())
  ownerId   String   @map("owner_id")
  members   Users[]
  tokens    Tokens[]
  boards    Boards[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("groups")
}

model Sessions {
  sessionId  String    @id
  expiryDate DateTime? @map("expiry_date")
  isExpired  Boolean   @map("is_expired")
  user       Users     @relation(fields: [userId], references: [id])
  userId     String    @map("user_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("sessions")
}

model Tokens {
  tokenId    String    @id
  expiryDate DateTime?
  isExpired  Boolean   @map("is_expired")
  user       Users?    @relation(fields: [userId], references: [id])
  userId     String?   @default("SERVER")
  group      Groups?   @relation(fields: [groupId], references: [id])
  groupId    String?   @default("SERVER")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("tokens")
}
